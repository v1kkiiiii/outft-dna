# Server-only secrets. Never commit real values. Never expose any of these
# via EXPO_PUBLIC_* or in mobile app code (SECURITY.md R-01).

# Anthropic API key. This REPLACES EXPO_PUBLIC_ANTHROPIC_API_KEY, which must
# be removed from the mobile app entirely (SECURITY.md release blocker R-01).
ANTHROPIC_API_KEY=

# Supabase project URL and SERVICE ROLE key (not the anon/publishable key).
# The service role key must only ever live here / in server env, never in
# mobile code or EXPO_PUBLIC_* vars.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Model identifier used for vision analysis calls (stamped into
# OutfitAnalysisV1.modelVersion).
ANALYSIS_MODEL=claude-sonnet-4-6

# Global analysis kill switch (ML.md §4.3). Must be exactly "true" to enable
# the worker to lease and process jobs; any other value disables it safely.
ANALYSIS_ENABLED=true
