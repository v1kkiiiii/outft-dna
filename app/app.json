{
  "expo": {
    "name": "outft.",
    "slug": "outft",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.outft.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.outft.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "OUTFT needs access to your photos so you can select an outfit to analyze."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "OUTFT uses the camera so you can capture your outfit."
        }
      ],
      "expo-secure-store"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F1EA"
    },
    "experiments": {
      "baseUrl": "/demo/app"
    },
    "extra": {
      "eas": {
        "projectId": "225fce5b-31d5-47b4-87e9-a7ab13c1209f"
      }
    },
    "owner": "sahana-lydia",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/225fce5b-31d5-47b4-87e9-a7ab13c1209f"
    }
  }
}